{
  "registry": {
    "type": "ecr",
    "region": "us-east-1"
  },
  "docker": {
    "socket_path": "/var/run/docker.sock",
    "label_filter": "dockenciler.autoupdate=true"
  },
  "reconcile_interval": "15m",
