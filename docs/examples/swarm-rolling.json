{
  "registry": {
    "type": "ecr",
    "ecr": {
      "region": "eu-west-1",
      "access_key": "YOUR_AWS_ACCESS_KEY_ID",
      "secret_key": "YOUR_AWS_SECRET_ACCESS_KEY"
    }
  },
  "docker": {
    "socket_path": "/var/run/docker.sock"
  },
  "notifications": {
    "slack_webhook_url": "https://hooks.slack.com/services/your-webhook-url"
  }
}
