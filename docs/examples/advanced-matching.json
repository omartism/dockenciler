{
  "registry": {
    "type": "ecr",
    "region": "us-east-1"
  },
  "docker": {
    "socket_path": "/var/run/docker.sock",
    "label_filter": "dockenciler.autoupdate=true"
  },
  "reconcile_interval": "1h",
  "log_level": "debug",
  "criteria": {
    "regex": "^v\\d+\\.\\d+\\.\\d+$"
  },
  "dry_run": true
}
