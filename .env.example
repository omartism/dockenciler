# Registry Configuration
# Type of registry to use: ecr, gcr
REGISTRY_TYPE=ecr

# ---------------------------------------------------------------------------
# ECR (Elastic Container Registry) — when REGISTRY_TYPE=ecr
# ---------------------------------------------------------------------------
# AWS Region for ECR
REGISTRY_ECR_REGION=us-west-2
# AWS Access Key for ECR authentication (leave empty to use IMDSv2 instance role)
REGISTRY_ECR_ACCESS_KEY=
# AWS Secret Key for ECR authentication
REGISTRY_ECR_SECRET_KEY=

# ---------------------------------------------------------------------------
# GCR / Artifact Registry — when REGISTRY_TYPE=gcr
# ---------------------------------------------------------------------------
# Authentication method: adc (Application Default Credentials) or service_account
# REGISTRY_GCR_AUTH_METHOD=adc
# Path to a Google Cloud service account JSON key file (required when auth_method=service_account)
# REGISTRY_GCR_AUTH_SERVICE_ACCOUNT_FILE=

# Docker Configuration
# Path to the Docker engine socket
DOCKER_SOCKET_PATH=/var/run/docker.sock
# Label used to identify containers that should be automatically updated
DOCKER_LABEL_FILTER="dockenciler.autoupdate=true"

# Application Settings
# How often to check for updates (e.g., 1h, 30m, 15s)
# Binary default: 1h. This file's `5m` is the Docker image default
# (overridden in `Dockerfile:33` via ENV).
RECONCILE_INTERVAL=5m
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Colorize log output (true/false)
COLOR_LOGS=true
# If true, preview updates without applying them
DRY_RUN=false
# Excluded container IDs. Use the JSON array form in config.json;
# the env-var comma-split form is unverified.
# EXCLUSIONS=

# Image Matching Criteria
# Target version or tag to match
CRITERIA_VERSION=
# Regex pattern to match image tags
CRITERIA_REGEX=
# Specific image digest to match
CRITERIA_DIGEST=

# Notification Configuration
# Slack webhook URL for notifications
NOTIFICATIONS_SLACK_WEBHOOK_URL=
# Discord webhook URL for notifications
NOTIFICATIONS_DISCORD_WEBHOOK_URL=
# Telegram bot token for notifications
NOTIFICATIONS_TELEGRAM_BOT_TOKEN=
# Telegram chat ID for notifications
NOTIFICATIONS_TELEGRAM_CHAT_ID=
# Email SMTP host
NOTIFICATIONS_EMAIL_HOST=
# Email SMTP port
NOTIFICATIONS_EMAIL_PORT=
# Email SMTP username
NOTIFICATIONS_EMAIL_USER=
# Email SMTP password
NOTIFICATIONS_EMAIL_PASSWORD=
# Email sender address
NOTIFICATIONS_EMAIL_FROM=
# Email recipient address
NOTIFICATIONS_EMAIL_TO=
# Microsoft Teams webhook URL for notifications
NOTIFICATIONS_MSTEAMS_WEBHOOK_URL=
# Google Chat webhook URL for notifications
NOTIFICATIONS_GOOGLE_CHAT_WEBHOOK_URL=

# Notification Templates (optional, Go text/template syntax)
# Override default template for all providers
NOTIFICATIONS_TEMPLATES_DEFAULT=
# Override per-provider templates
NOTIFICATIONS_TEMPLATES_SLACK=
NOTIFICATIONS_TEMPLATES_DISCORD=
NOTIFICATIONS_TEMPLATES_TELEGRAM=
NOTIFICATIONS_TEMPLATES_EMAIL=
NOTIFICATIONS_TEMPLATES_MSTEAMS=
NOTIFICATIONS_TEMPLATES_GOOGLE_CHAT=
