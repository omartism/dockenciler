# Registry Configuration
# Type of registry to use: ecr, gcr
DOCKENCILER_REGISTRY_TYPE=ecr

# ---------------------------------------------------------------------------
# ECR (Elastic Container Registry) — when DOCKENCILER_REGISTRY_TYPE=ecr
# ---------------------------------------------------------------------------
# AWS Region for ECR
DOCKENCILER_REGISTRY_ECR_REGION=us-west-2
# AWS Access Key for ECR authentication (leave empty to use IMDSv2 instance role)
DOCKENCILER_REGISTRY_ECR_ACCESS_KEY=
# AWS Secret Key for ECR authentication
DOCKENCILER_REGISTRY_ECR_SECRET_KEY=

# ---------------------------------------------------------------------------
# GCR / Artifact Registry — when DOCKENCILER_REGISTRY_TYPE=gcr
# ---------------------------------------------------------------------------
# Authentication method: adc (Application Default Credentials) or service_account
# DOCKENCILER_REGISTRY_GCR_AUTH_METHOD=adc
# Path to a Google Cloud service account JSON key file (required when auth_method=service_account)
# DOCKENCILER_REGISTRY_GCR_AUTH_SERVICE_ACCOUNT_FILE=

# Docker Configuration
# Path to the Docker engine socket
DOCKENCILER_DOCKER_SOCKET_PATH=/var/run/docker.sock
# Label used to identify containers that should be automatically updated
DOCKENCILER_DOCKER_LABEL_FILTER="dockenciler.autoupdate=true"

# Application Settings
# How often to check for updates (e.g., 1h, 30m, 15s)
# Binary default: 1h. This file's `5m` is the Docker image default
# (overridden in `Dockerfile:33` via ENV).
DOCKENCILER_RECONCILE_INTERVAL=5m
# Log level: debug, info, warn, error
DOCKENCILER_LOG_LEVEL=info
# Colorize log output (true/false)
DOCKENCILER_COLOR_LOGS=true
# If true, preview updates without applying them
DOCKENCILER_DRY_RUN=false
# Excluded container IDs. Use the JSON array form in config.json;
# the env-var comma-split form is unverified.
# DOCKENCILER_EXCLUSIONS=

# Image Matching Criteria
# Target version or tag to match
DOCKENCILER_CRITERIA_VERSION=
# Regex pattern to match image tags
DOCKENCILER_CRITERIA_REGEX=
# Specific image digest to match
DOCKENCILER_CRITERIA_DIGEST=

# Notification Configuration
# Slack webhook URL for notifications
DOCKENCILER_NOTIFICATIONS_SLACK_WEBHOOK_URL=
# Discord webhook URL for notifications
DOCKENCILER_NOTIFICATIONS_DISCORD_WEBHOOK_URL=
# Telegram bot token for notifications
DOCKENCILER_NOTIFICATIONS_TELEGRAM_BOT_TOKEN=
# Telegram chat ID for notifications
DOCKENCILER_NOTIFICATIONS_TELEGRAM_CHAT_ID=
# Email SMTP host
DOCKENCILER_NOTIFICATIONS_EMAIL_HOST=
# Email SMTP port
DOCKENCILER_NOTIFICATIONS_EMAIL_PORT=
# Email SMTP username
DOCKENCILER_NOTIFICATIONS_EMAIL_USER=
# Email SMTP password
DOCKENCILER_NOTIFICATIONS_EMAIL_PASSWORD=
# Email sender address
DOCKENCILER_NOTIFICATIONS_EMAIL_FROM=
# Email recipient address
DOCKENCILER_NOTIFICATIONS_EMAIL_TO=
# Microsoft Teams webhook URL for notifications
DOCKENCILER_NOTIFICATIONS_MSTEAMS_WEBHOOK_URL=
# Google Chat webhook URL for notifications
DOCKENCILER_NOTIFICATIONS_GOOGLE_CHAT_WEBHOOK_URL=

# Notification Templates (optional, Go text/template syntax)
# Override default template for all providers
DOCKENCILER_NOTIFICATIONS_TEMPLATES_DEFAULT=
# Override per-provider templates
DOCKENCILER_NOTIFICATIONS_TEMPLATES_SLACK=
DOCKENCILER_NOTIFICATIONS_TEMPLATES_DISCORD=
DOCKENCILER_NOTIFICATIONS_TEMPLATES_TELEGRAM=
DOCKENCILER_NOTIFICATIONS_TEMPLATES_EMAIL=
DOCKENCILER_NOTIFICATIONS_TEMPLATES_MSTEAMS=
DOCKENCILER_NOTIFICATIONS_TEMPLATES_GOOGLE_CHAT=
